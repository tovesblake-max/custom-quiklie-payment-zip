# Quiklie API credentials — find these in your Quiklie dashboard:
#   - Merchant ID:   Profile → "User ID" (numeric, e.g. 171)
#   - API Key:       Profile → "API Key" (long alphanumeric string)
#
# Both are REQUIRED. The plugin throws on cold start if either is missing
# in production (process.env.NODE_ENV === "production").
QUIKLIE_MERCHANT_ID=
QUIKLIE_API_KEY=

# Webhook validation key — Quiklie posts to your /api/quiklie/notify
# endpoint with this key in the `x-api-key` header. Almost always the
# SAME value as QUIKLIE_API_KEY (per Quiklie's standard configuration).
# Confirm with Quiklie support if you've been issued a separate key.
QUIKLIE_WEBHOOK_API_KEY=

# Statement descriptor — what appears on the customer's bank statement.
# Quiklie hard-caps at 22 characters. Get this assigned to you by
# Quiklie when your MID is provisioned. Example: "MYSTORE.COM" or the
# acquirer's routing entity (e.g. "DTF HORIZONTRV").
QUIKLIE_DESCRIPTOR=

# midType — selects the processor lane.
#   - THREE_D: 3DS-enabled lane (SCA challenge; default for fresh-card
#              transactions in 2026, required by most modern processors)
#   - TWO_D:   no 3DS challenge (faster, only works on processors that
#              don't enforce SCA)
# Leave unset to default to THREE_D.
NEXT_PUBLIC_QUIKLIE_HPP_MIDTYPE=THREE_D

# Minimum transaction amount in cents. Quiklie's acquirer rejects sub-
# minimum amounts with an opaque error; we surface a clean customer-
# facing message instead. Quiklie default is $15 ($1500 cents).
QUIKLIE_MIN_TXN_CENTS=1500

# Your site's canonical URL — used to build the callback + redirect
# URLs sent to Quiklie. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://your-site.com
